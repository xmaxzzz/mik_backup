{
    # Browsers/clients don't send SNI when the URL host is a bare IP literal
    # (RFC 6066) — this tells Caddy which certificate to serve for those
    # SNI-less connections, which is otherwise all of them on this LAN box.
    #
    # The address is taken from the SERVER_IP env var (passed in by
    # docker-compose from .env), so a new deployment only sets it once —
    # no Caddyfile edits. Falls back to the original LAN IP if unset.
    default_sni {$SERVER_IP:192.168.200.121}
}

https://{$SERVER_IP:192.168.200.121} {
    tls internal
    encode zstd gzip

    # Download Caddy's internal root CA so it can be trusted on clients.
    # Needed for the in-browser SSH terminal: browsers block wss:// to an
    # untrusted cert. Install this once (Trusted Root Certification Authorities)
    # and both HTTPS and the terminal work without warnings.
    @ca path /mik-ca.crt
    handle @ca {
        root * /data/caddy/pki/authorities/local
        rewrite * /root.crt
        header Content-Disposition "attachment; filename=mik-ca.crt"
        file_server
    }

    handle {
        reverse_proxy app:8000
    }
}

http://{$SERVER_IP:192.168.200.121} {
    redir https://{host}{uri} permanent
}
