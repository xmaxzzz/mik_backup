# ---------------------------------------------------------------------------
# Mikrotik Backup — environment configuration
# Copy to `.env` and fill in real secrets. NEVER commit the real `.env`.
#
# Generate secrets:
#   SECRET_KEY       python3 -c "import secrets; print(secrets.token_urlsafe(48))"
#   ENCRYPTION_KEY   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   ADMIN_PASSWORD   python3 -c "import secrets; print(secrets.token_urlsafe(12))"
# ---------------------------------------------------------------------------

# JWT signing key (any long random string)
SECRET_KEY=

# Fernet key used to encrypt device credentials at rest (MUST be a valid Fernet key)
ENCRYPTION_KEY=

# Initial admin account (created on first startup only)
ADMIN_USER=admin
ADMIN_PASSWORD=

# --- optional tuning (sensible defaults, override if needed) ---
# How often scheduled backups of all enabled devices run
BACKUP_INTERVAL_HOURS=24
# Keep only the N most recent successful backups per device (0 = keep all)
BACKUP_RETENTION=30
# Set to false to disable the background scheduler
SCHEDULER_ENABLED=true
# Access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=720
