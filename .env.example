# ---------------------------------------------------------------------------
# Mikrotik Backup — environment configuration
#
# THIS FILE IS OPTIONAL. With no .env at all, the app auto-generates its
# secrets on first start (persisted in data/instance.env) and the initial admin
# password is printed to the logs — so `docker compose up -d` just works.
#
# Copy to `.env` only if you want to pin values yourself. NEVER commit a real
# .env. Any value left blank here falls back to the auto-generated one.
# ---------------------------------------------------------------------------

# JWT signing key — blank = auto-generated & persisted in data/instance.env
SECRET_KEY=

# Fernet key encrypting device credentials + tokens at rest — blank = auto.
# If you set it, it MUST be a valid Fernet key.
ENCRYPTION_KEY=

# Initial admin account (created on first startup only).
# ADMIN_PASSWORD blank = auto-generated (see logs / data/instance.env).
ADMIN_USER=admin
ADMIN_PASSWORD=

# --- server address ---
# LAN/VPN IP (or hostname) of THIS server. This is the address Caddy issues its
# TLS certificate for and serves on, so the app is reachable at https://SERVER_IP.
# Set it once here; to change it later, edit this line and run:
#   docker compose up -d --force-recreate caddy
# (bootstrap.sh fills this in automatically.)
SERVER_IP=

# Default SSH port suggested for new / imported devices
DEFAULT_SSH_PORT=10322

# Keep only the N most recent successful backups per device (0 = keep all)
BACKUP_RETENTION=30

# How often (seconds) every device is TCP-probed for the online/offline dot
AVAILABILITY_INTERVAL_SEC=60

# Set to false to disable all background jobs (backups + availability)
SCHEDULER_ENABLED=true

# Access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=720

# NOTE: backup timing is now managed by "Schedules" in the UI (cron per schedule),
# not by a global interval. Telegram + Yandex.Disk are configured in the UI too.
