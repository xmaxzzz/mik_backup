# ---------------------------------------------------------------------------
# Mikrotik Backup — environment configuration
# Copy to `.env` and fill in real secrets. NEVER commit the real `.env`.
#
# Generate secrets:
#   SECRET_KEY       python3 -c "import secrets; print(secrets.token_urlsafe(48))"
#   ENCRYPTION_KEY   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   ADMIN_PASSWORD   python3 -c "import secrets; print(secrets.token_urlsafe(12))"
# ---------------------------------------------------------------------------

# JWT signing key (any long random string)
SECRET_KEY=

# Fernet key used to encrypt device credentials + tokens at rest
# (MUST be a valid Fernet key)
ENCRYPTION_KEY=

# Initial admin account (created on first startup only)
ADMIN_USER=admin
ADMIN_PASSWORD=

# --- optional tuning (sensible defaults, override if needed) ---
# LAN/VPN address of THIS server that routers connect back to.
# Used only to fill the ready-to-paste RouterOS script under "SSH-ключ".
SERVER_IP=

# Default SSH port suggested for new / imported devices
DEFAULT_SSH_PORT=10322

# Keep only the N most recent successful backups per device (0 = keep all)
BACKUP_RETENTION=30

# How often (seconds) every device is TCP-probed for the online/offline dot
AVAILABILITY_INTERVAL_SEC=60

# Set to false to disable all background jobs (backups + availability)
SCHEDULER_ENABLED=true

# Access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=720

# NOTE: backup timing is now managed by "Schedules" in the UI (cron per schedule),
# not by a global interval. Telegram + Yandex.Disk are configured in the UI too.
